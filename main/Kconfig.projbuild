menu "Snoring Detector Configuration"

    config SNORING_WIFI_SSID
        string "WiFi SSID"
        default ""
        help
            SSID (network name) to connect to.

    config SNORING_WIFI_PASSWORD
        string "WiFi Password"
        default ""
        help
            WiFi password (WPA or WPA2).

    config SNORING_MQTT_BROKER_URI
        string "MQTT Broker URI"
        default "mqtt://127.0.0.1:1883"
        help
            MQTT broker URI.

endmenu
